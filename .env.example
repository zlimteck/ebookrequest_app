NODE_ENV=production
PORT=5001
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ebookrequest?retryWrites=true&w=majority
JWT_SECRET=change_me_with_a_long_random_string
FRONTEND_URL=https://ebook.tondomaine.fr
GOOGLE_BOOKS_API_KEY=your_google_books_api_key
EMAIL_PROVIDER=smtp
SMTP_HOST=your_smtp_host
SMTP_PORT=your_smtp_port
SMTP_SECURE=true
SMTP_USER=noreply@tondomaine.fr
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM_ADDRESS=noreply@tondomaine.fr
EMAIL_FROM_NAME=EbookRequest
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
APPRISE_URL=http://apprise:8000
APPRISE_CONFIG_PATH=./apprise-config
TZ=Europe/Paris
RSS_FEED_URL=https://predb.me/?cats=books-ebooks&rss=1
# AI_PROVIDER can be 'openai', 'ollama', or 'claude'
AI_PROVIDER=openai
# OpenAI
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-proj-xxx
# Ollama
OLLAMA_URL=http://172.17.0.x:11434
OLLAMA_MODEL=EbookRequest_AI
OLLAMA_TIMEOUT=60000
# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-opus-4-5